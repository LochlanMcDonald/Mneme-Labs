{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "*.png", "*.svg", "*.ico", "*.txt"]
  },
  "routes": [
    {
      "route": "/api/stripe-webhook",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "platform": {
    "apiRuntime": "node:20"
  }
}
